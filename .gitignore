# =============================================================================
# trading-research — .gitignore
# High-fidelity: excludes data, logs, venvs, caches; preserves directory skeleton.
# =============================================================================

# -----------------------------------------------------------------------------
# Python runtime / build artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
*.egg
build/
dist/
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# uv / package managers
# -----------------------------------------------------------------------------
.uv/
# uv.lock IS committed — do not ignore it.

# -----------------------------------------------------------------------------
# Test / lint / type-check caches
# -----------------------------------------------------------------------------
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.pytype/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# -----------------------------------------------------------------------------
# Jupyter / notebook artifacts
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
notebooks/*.ipynb
notebooks/scratch/
!notebooks/.gitkeep

# -----------------------------------------------------------------------------
# Project data layers (RAW / CLEAN / FEATURES) — exclude all bulk payloads,
# keep the directory skeleton and manifests/quality sidecars that describe
# what *should* be there.
# -----------------------------------------------------------------------------
data/raw/**
data/clean/**
data/features/**

# Preserve layer directories and the dotfiles that mark them
!data/
!data/raw/
!data/clean/
!data/features/
!data/raw/.gitkeep
!data/clean/.gitkeep
!data/features/.gitkeep

# Preserve manifest + quality sidecars so the layer state is describable
# without shipping the payloads.
!data/raw/**/*.manifest.json
!data/clean/**/*.manifest.json
!data/features/**/*.manifest.json
!data/raw/**/*.quality.json
!data/clean/**/*.quality.json

# Preserve `known_outages.yaml` and any other YAML catalog under data/
!data/**/*.yaml
!data/**/*.yml

# -----------------------------------------------------------------------------
# Backtest / run outputs
# -----------------------------------------------------------------------------
runs/**
!runs/
!runs/.gitkeep

# -----------------------------------------------------------------------------
# Migration artifacts (generated by prep_migration_samples.py — small, but
# regenerable and host-specific, so do not commit)
# -----------------------------------------------------------------------------
migration_samples/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
outputs/logs/
*.log.*
# Keep session work-logs — they are project memory, not runtime logs.
!outputs/work-log/
!outputs/work-log/**/*.md

# -----------------------------------------------------------------------------
# Reports / large HTML exports (generated, regenerable from runs/)
# -----------------------------------------------------------------------------
outputs/reports/*.html
outputs/reports/*.html.gz
!outputs/reports/.gitkeep

# -----------------------------------------------------------------------------
# Legacy content — preserve scaffold only, not imported code trees
# -----------------------------------------------------------------------------
Legacy/**/__pycache__/
Legacy/**/.venv/
Legacy/**/*.parquet
Legacy/**/*.csv
Legacy/**/*.log

# -----------------------------------------------------------------------------
# Secrets / credentials — never commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
configs/secrets.yaml
configs/secrets.*.yaml
*.pem
*.key
*_credentials.json
*_token.json
tradestation_tokens.json

# -----------------------------------------------------------------------------
# OS / editor / tooling
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.vscode/
.idea/
*.swp
*.swo
*~
.claude/local/
.antigravity/

# -----------------------------------------------------------------------------
# Binary / archive / bulk payloads that should never be in git
# -----------------------------------------------------------------------------
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Allow small fixture parquets under tests/ (explicit opt-in)
!tests/**/*.parquet

# -----------------------------------------------------------------------------
# Scratch / Temporary files
# -----------------------------------------------------------------------------
patch_*.py
pytest_out.txt
