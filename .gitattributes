# Normalize line endings: LF in repo, CRLF on Windows checkout
* text=auto

# Force LF for shell scripts and Python source
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.j2 text eol=lf
*.html text eol=lf

# Binary files — never convert
*.parquet binary
*.pyc binary
*.pyd binary
*.so binary
