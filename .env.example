# TradeStation WebAPI v3 credentials.
# Copy this file to .env and fill in the values. The .env file is gitignored.
#
# Obtain client_id and client_secret from the TradeStation developer portal.
# The refresh_token is issued by the OAuth Authorization Code flow and is
# long-lived by default. If the key is configured to rotate, the auth module
# will rewrite this file in place when a new refresh token is issued.

TRADESTATION_CLIENT_ID=
TRADESTATION_CLIENT_SECRET=
TRADESTATION_REFRESH_TOKEN=

# Optional. Override the API base URL. Defaults to the live API.
# Use https://sim-api.tradestation.com for the simulation environment.
TRADESTATION_API_BASE_URL=https://api.tradestation.com
